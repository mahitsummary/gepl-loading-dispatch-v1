{
  "name": "gepl-app",
  "version": "1.0.0",
  "description": "GEPL - Loading and Dispatched V1 - Material Tracking and Reconciliation System",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "gas:push": "cd google-apps-script && clasp push",
